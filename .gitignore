.matplotlib_cache/
~/
.ipynb_checkpoints/
.vscode/
.broadcast.py.swp
.DS_Store
*.pyc
./driver/.DS_Store
./emulator/.DS_Store

# per-machine Claude Code local settings (permission grants etc.); keep role
# files and commands tracked, just not this one
.claude/settings.local.json

# Linked checkouts plus the mailbox daemon's primary-worktree state, lock, and
# interrupted atomic-write temporaries are repo-local runtime infrastructure.
.claude/worktrees/

# LaTeX scratch files.  Keep the reader-facing PDF and vector figures tracked;
# these files are compiler state that is regenerated during every clean build.
documentation/*.aux
documentation/*.log
documentation/*Notes.bib

# agent relay transport (never committed)
ai/notes/mailbox/
ai/notes/relay/

# Only the eleven permanent, general-property notes belong in Git.  Every other
# top-level Markdown note is a local ticket record.
/ai/notes/*.md
!/ai/notes/MEMORY.md
!/ai/notes/artifacts-inference-warmstart.md
!/ai/notes/conventions-and-workflow.md
!/ai/notes/data-generation-and-cuts.md
!/ai/notes/families-background-mps.md
!/ai/notes/families-scalar-cmb.md
!/ai/notes/models-and-designs.md
!/ai/notes/project-and-history.md
!/ai/notes/readme-go-no-go.md
!/ai/notes/training-stack.md
!/ai/notes/python-changes-go-no-go.md

# Offline backlog handoffs and their review staging are local transport.
# Supporting attachments live here so an email bundle can collect them
# without putting either the sources or the generated .xz file on GitHub.
/ai/notes/backlog-support/
/ai/backlog-bundles/
/ai/backlog-imports/
*.backlog-bundle.tar.xz
